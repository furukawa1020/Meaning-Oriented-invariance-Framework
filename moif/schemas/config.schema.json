{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MOIF Config",
  "type": "object",
  "required": ["dataset", "signals", "banding", "detection", "logging"],
  "properties": {
    "dataset": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["wesad", "csv"] },
        "path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "signals": {
      "type": "array",
      "items": { "type": "string", "enum": ["HR", "EDA"] },
      "minItems": 1
    },
    "banding": {
      "type": "object",
      "required": ["mode", "min_n_per_condition"],
      "properties": {
        "mode": { "type": "string", "enum": ["abs", "norm"] },
        "abs": {
          "type": "object",
          "properties": { "low": { "type": "number" }, "high": { "type": "number" } },
          "required": ["low", "high"]
        },
        "norm": {
          "type": "object",
          "properties": {
            "method": { "type": "string", "enum": ["z", "quantile"] },
            "z_low": { "type": "number" },
            "z_high": { "type": "number" },
            "q_low": { "type": "number" },
            "q_high": { "type": "number" }
          },
          "required": ["method"]
        },
        "min_n_per_condition": { "type": "integer", "minimum": 10 }
      }
    },
    "detection": {
      "type": "object",
      "required": ["divergence_metric", "permutation", "fdr_alpha"],
      "properties": {
        "divergence_metric": { "type": "string", "enum": ["JSD"] },
        "permutation": {
          "type": "object",
          "required": ["n_perm", "seed"],
          "properties": {
            "n_perm": { "type": "integer", "minimum": 100 },
            "seed": { "type": "integer" }
          }
        },
        "fdr_alpha": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "logging": {
      "type": "object",
      "required": ["run_id_strategy"],
      "properties": {
        "run_id_strategy": { "type": "string", "enum": ["timestamp_hash"] }
      }
    }
  },
  "additionalProperties": true
}
